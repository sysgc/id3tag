ACOUSTID_API_KEY=

# host path to your music library — mounted read-write into the container at /music
MUSIC_DIR=/path/to/your/music

# host path for this app's own data (just the scan cache — no audio file
# backups are kept, see README's "Why no backups") — mounted at /data.
# a plain folder (bind mount, not a docker volume) so it survives container
# rebuilds. created automatically if missing.
APP_DATA_DIR=/Users/sundarkr/VSCode/id3tag/data

# host port the app (uvicorn) listens on directly, e.g. http://localhost:8080
HOST_PORT=8080
